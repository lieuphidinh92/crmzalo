{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://halo-sale-backend.onrender.com/api/:path*"
    },
    {
      "source": "/socket.io/:path*",
      "destination": "https://halo-sale-backend.onrender.com/socket.io/:path*"
    },
    {
      "source": "/:path*",
      "destination": "/index.html"
    }
  ]
}
