generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// Top-level org — every resource is scoped to an org
model Organization {
  id        String   @id @default(uuid())
  name      String
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  teams               Team[]
  users               User[]
  zaloAccounts        ZaloAccount[]
  contacts            Contact[]
  conversations       Conversation[]
  appointments        Appointment[]
  jobs                Job[]
  activityLogs        ActivityLog[]
  dailyStats          DailyMessageStat[]
  settings            AppSetting[]
  orders              Order[]
  quickReplyTemplates QuickReplyTemplate[]
  tasks               Task[]
  recurringTaskRules  RecurringTaskRule[]
  autoTaskRules       AutoTaskRule[]
  learningModules     LearningModule[]
  suppliers           Supplier[]
  brands              Brand[]
  products            Product[]
  warehouses          Warehouse[]
  inventoryBatches    InventoryBatch[]
  inventoryMovements  InventoryMovement[]
  importOrders        ImportOrder[]

  @@map("organizations")
}

// Team groups within an organization
model Team {
  id        String   @id @default(uuid())
  orgId     String   @map("org_id")
  name      String
  createdAt DateTime @default(now()) @map("created_at")

  org   Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  users User[]

  @@map("teams")
}

// CRM user with role-based access
model User {
  id           String   @id @default(uuid())
  orgId        String   @map("org_id")
  teamId       String?  @map("team_id")
  email        String   @unique
  passwordHash String   @map("password_hash")
  fullName     String   @map("full_name")
  role         String   @default("member") // owner, admin, member
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  org              Organization        @relation(fields: [orgId], references: [id], onDelete: Cascade)
  team             Team?               @relation(fields: [teamId], references: [id])
  zaloAccounts     ZaloAccount[]
  zaloAccess       ZaloAccountAccess[]
  assignedContacts Contact[]           @relation("AssignedContacts")
  appointments     Appointment[]
  repliedMessages  Message[]           @relation("RepliedMessages")
  activityLogs     ActivityLog[]
  createdOrders    Order[]             @relation("CreatedOrders")
  saleOrders       Order[]             @relation("AssignedSaleOrders")
  mktOrders        Order[]             @relation("MktOwnerOrders")
  assignedTasks    Task[]              @relation("AssignedTasks")
  learningProgress LearningProgress[]

  @@map("users")
}

// Zalo account linked to a user (one user may own multiple Zalo accounts)
model ZaloAccount {
  id              String    @id @default(uuid())
  orgId           String    @map("org_id")
  ownerUserId     String    @map("owner_user_id")
  zaloUid         String?   @unique @map("zalo_uid")
  displayName     String?   @map("display_name")
  avatarUrl       String?   @map("avatar_url")
  phone           String?
  status          String    @default("disconnected") // connected, disconnected, qr_pending
  sessionData     Json?     @map("session_data")
  lastConnectedAt DateTime? @map("last_connected_at")
  createdAt       DateTime  @default(now()) @map("created_at")

  org           Organization        @relation(fields: [orgId], references: [id], onDelete: Cascade)
  owner         User                @relation(fields: [ownerUserId], references: [id])
  access        ZaloAccountAccess[]
  conversations Conversation[]
  dailyStats    DailyMessageStat[]

  @@map("zalo_accounts")
}

// ACL: which users can access which Zalo accounts
model ZaloAccountAccess {
  id            String   @id @default(uuid())
  zaloAccountId String   @map("zalo_account_id")
  userId        String   @map("user_id")
  permission    String   @default("read") // read, chat, admin
  createdAt     DateTime @default(now()) @map("created_at")

  zaloAccount ZaloAccount @relation(fields: [zaloAccountId], references: [id], onDelete: Cascade)
  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([zaloAccountId, userId])
  @@map("zalo_account_access")
}

// Customer / contact record (B2B sales — TPCN wholesale)
model Contact {
  id                    String    @id @default(uuid())
  orgId                 String    @map("org_id")
  // Mã KH thân thiện cho anh Philip — KH001, KH002... Cấp tự động khi
  // tạo KH mới (xem customer-code-service.ts). Backfill cho 254 KH cũ
  // qua scripts/backfill-customer-codes.ts. Unique constraint sẽ thêm
  // sau khi backfill xong (tránh fail migration nếu có row chưa gán).
  customerCode          String?   @map("customer_code")
  zaloUid               String?   @map("zalo_uid")
  phone                 String?
  fullName              String?   @map("full_name")
  facebookId            String?   @map("facebook_id")
  pancakeConversationId String?   @map("pancake_conversation_id")
  misaCustomerCode      String?   @map("misa_customer_code")
  avatarUrl             String?   @map("avatar_url")
  source                String? // FB, TT, GT, CN, zalo, gioi_thieu, khac
  sourceDate            DateTime? @map("source_date")
  firstContactDate      DateTime? @map("first_contact_date")
  assignedUserId        String?   @map("assigned_user_id")
  notes                 String?
  tags                  Json      @default("[]")
  metadata              Json      @default("{}")

  // === B2B sales fields (added for ngheduocsi.vn refactor) ====================
  // All fields nullable / default-empty so existing rows don't break.
  storeName              String?   @map("store_name")
  province               String?
  address                String?
  customerType           String?   @map("customer_type") // nha_thuoc | si_online | duoc_si | cua_hang_me_be
  scale                  String? // nho | vua | lon
  // Hồ sơ xuất hóa đơn VAT mặc định của KH (đơn mới tự điền sẵn, vẫn sửa được).
  invoiceBuyerType       String?   @map("invoice_buyer_type") // ca_nhan | ho_kinh_doanh | cong_ty
  invoiceBuyerName       String?   @map("invoice_buyer_name")
  invoiceTaxCode         String?   @map("invoice_tax_code")
  invoiceAddress         String?   @map("invoice_address")
  invoiceEmail           String?   @map("invoice_email")
  currentProducts        Json      @default("[]") @map("current_products")
  currentSupplier        String?   @map("current_supplier")
  monthlyRevenueEstimate String?   @map("monthly_revenue_estimate")
  avgOrderQuantity       String?   @map("avg_order_quantity")
  stage                  String? // tiep_can | da_bao_gia | dang_thu_hang | dai_ly_chinh_thuc | ngung
  stuckReason            String?   @map("stuck_reason")
  policyTier             String?   @map("policy_tier") // ctv | dai_ly_cap_1 | dai_ly_cap_2
  debtAmount             Decimal?  @map("debt_amount") @db.Decimal(15, 2)
  creditLimit            Decimal?  @map("credit_limit") @db.Decimal(15, 2) // hạn mức công nợ
  lastOrderDate          DateTime? @map("last_order_date")
  nextContactDate        DateTime? @map("next_contact_date")
  internalNote           String?   @map("internal_note")
  rewardPoints           Int       @default(0) @map("reward_points")
  aiInsight              Json?     @map("ai_insight") // structured Claude output
  aiInsightUpdatedAt     DateTime? @map("ai_insight_updated_at")
  // Pipeline / opportunity tracking ------------------------------------
  potentialValue         Decimal?  @map("potential_value") @db.Decimal(15, 2)
  stageUpdatedAt         DateTime? @map("stage_updated_at")
  // ===========================================================================

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  org           Organization   @relation(fields: [orgId], references: [id], onDelete: Cascade)
  assignedUser  User?          @relation("AssignedContacts", fields: [assignedUserId], references: [id])
  conversations Conversation[]
  appointments  Appointment[]
  orders        Order[]
  stageHistory  StageHistory[]
  tasks         Task[]

  @@index([orgId, customerType])
  @@index([orgId, stage])
  @@index([orgId, province])
  @@index([orgId, phone])
  @@index([orgId, misaCustomerCode])
  @@index([orgId, customerCode])
  // Chặn trùng SĐT trong cùng org. NULL được phép nhiều (KH chưa xin SĐT)
  // — PostgreSQL unique cho phép multiple NULLs by default. Áp sau khi
  // backfill: dedup (16 nhóm merge) + normalize (chuẩn 10 số bắt đầu 0).
  @@unique([orgId, phone], map: "contacts_org_id_phone_unique")
  @@map("contacts")
}

// Inbound webhook payloads (Pancake, future integrations).
// One row per webhook delivery — used for debugging / replay.
model WebhookLog {
  id           String   @id @default(uuid())
  orgId        String?  @map("org_id")
  source       String // pancake | future-source
  payload      Json     @default("{}")
  status       String // received | success | failed | duplicate | unauthorized
  errorMessage String?  @map("error_message")
  createdAt    DateTime @default(now()) @map("created_at")

  @@index([source, createdAt])
  @@map("webhook_logs")
}

// Audit trail for B2B sales-stage transitions. One row per stage change
// (drag-drop on the pipeline page or any code that touches Contact.stage).
// Powers the "thời gian TB từ tiếp cận → chốt" metric and the per-deal
// timeline view we'll build later.
// Per-sale behaviour log used by the compliance-score sub-metric on the
// CEO Dashboard. Inserted by lightweight hooks in contact / chat / AI
// routes — no app code reads this table directly except the score
// calculator (sale-performance-service.ts).
model SaleComplianceLog {
  id         String   @id @default(uuid())
  orgId      String   @map("org_id")
  saleId     String   @map("sale_id")
  actionType String   @map("action_type") // note_updated | stage_updated | zalo_replied | ai_insight_used
  contactId  String?  @map("contact_id")
  actionAt   DateTime @default(now()) @map("action_at")
  metadata   Json     @default("{}")

  @@index([orgId, saleId, actionAt])
  @@index([orgId, actionType, actionAt])
  @@map("sale_compliance_log")
}

// CEO-tunable weights + targets for the 6 sale-score metrics. One row
// per (orgId, metricKey). Seeded with the spec defaults on first GET.
model SaleScoreConfig {
  id          String   @id @default(uuid())
  orgId       String   @map("org_id")
  metricKey   String   @map("metric_key") // resale_revenue | active_rate | new_agents | conversion_rate | retention_90d | compliance_score
  weight      Decimal  @db.Decimal(5, 2) // % out of 100 (e.g. 25.00)
  targetValue Decimal? @map("target_value") @db.Decimal(15, 2) // optional absolute target (informational)
  updatedBy   String?  @map("updated_by")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@unique([orgId, metricKey])
  @@map("sale_score_config")
}

// Org-scoped pricing rule for the sale-app tier backfill job. One row per
// org, seeded with defaults on first GET. Drives the formula:
//   base = cost_price * (1 + costMarkupPct/100)   ← Đại lý cấp 2 (VIP)
//   Cấp 1 = base + tierDelta
//   CTV   = base + 2 * tierDelta
// `enableBackfill` is a safety flag; the backfill endpoint refuses to
// touch the DB unless an admin has flipped this to true at least once.
model SaleAppPricingConfig {
  id              String   @id @default(uuid())
  orgId           String   @unique @map("org_id")
  costMarkupPct   Decimal  @default(25) @map("cost_markup_pct") @db.Decimal(6, 2)
  tierDelta       Decimal  @default(5000) @map("tier_delta") @db.Decimal(15, 2)
  enableBackfill  Boolean  @default(false) @map("enable_backfill")
  lastBackfillAt  DateTime? @map("last_backfill_at")
  updatedBy       String?  @map("updated_by")
  updatedAt       DateTime @updatedAt @map("updated_at")

  @@map("sale_app_pricing_config")
}

model StageHistory {
  id              String   @id @default(uuid())
  contactId       String   @map("contact_id")
  fromStage       String?  @map("from_stage") // null on first entry
  toStage         String   @map("to_stage")
  changedAt       DateTime @default(now()) @map("changed_at")
  changedByUserId String?  @map("changed_by_user_id")
  reason          String?

  contact Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)

  @@index([contactId, changedAt])
  @@map("stage_history")
}

// Unified patient record — one patient may have multiple Zalo contacts
// A chat thread between a Zalo account and a contact (or group)
model Conversation {
  id               String    @id @default(uuid())
  orgId            String    @map("org_id")
  zaloAccountId    String    @map("zalo_account_id")
  contactId        String?   @map("contact_id")
  threadType       String    @default("user") // user, group
  // Display name for group threads. NULL for 1-1 user conversations
  // (those use the linked contact's fullName instead). Populated by
  // the listener from `getGroupInfo()` and refreshed when the Zalo
  // group is renamed.
  title            String?
  externalThreadId String?   @map("external_thread_id")
  lastMessageAt    DateTime? @map("last_message_at")
  unreadCount      Int       @default(0) @map("unread_count")
  isReplied        Boolean   @default(true) @map("is_replied")
  createdAt        DateTime  @default(now()) @map("created_at")

  org         Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  zaloAccount ZaloAccount  @relation(fields: [zaloAccountId], references: [id], onDelete: Cascade)
  contact     Contact?     @relation(fields: [contactId], references: [id])
  messages    Message[]
  orders      Order[]

  @@unique([zaloAccountId, externalThreadId])
  @@map("conversations")
}

// Individual message within a conversation
model Message {
  id              String    @id @default(uuid())
  conversationId  String    @map("conversation_id")
  zaloMsgId       String?   @map("zalo_msg_id")
  senderType      String    @map("sender_type") // self, contact
  senderUid       String?   @map("sender_uid")
  senderName      String?   @map("sender_name")
  content         String?
  contentType     String    @default("text") @map("content_type") // text, image, file, sticker, voice, video, link
  attachments     Json      @default("[]")
  isDeleted       Boolean   @default(false) @map("is_deleted")
  deletedAt       DateTime? @map("deleted_at")
  sentAt          DateTime  @map("sent_at")
  repliedByUserId String?   @map("replied_by_user_id")
  createdAt       DateTime  @default(now()) @map("created_at")

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  repliedBy    User?        @relation("RepliedMessages", fields: [repliedByUserId], references: [id])

  @@map("messages")
}

// Medical appointment scheduled for a contact
model Appointment {
  id              String   @id @default(uuid())
  orgId           String   @map("org_id")
  contactId       String   @map("contact_id")
  assignedUserId  String?  @map("assigned_user_id")
  appointmentDate DateTime @map("appointment_date")
  appointmentTime String?  @map("appointment_time")
  type            String? // tai_kham, kham_moi, online
  status          String   @default("scheduled") // scheduled, completed, cancelled, no_show
  notes           String?
  reminderSent    Boolean  @default(false) @map("reminder_sent")
  createdAt       DateTime @default(now()) @map("created_at")

  org          Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  contact      Contact      @relation(fields: [contactId], references: [id], onDelete: Cascade)
  assignedUser User?        @relation(fields: [assignedUserId], references: [id])

  @@map("appointments")
}

// ICD-10 disease code lookup table (seeded from markdown file)
// Scheduled automation job (QC, classify, reminder, stats)
model Job {
  id           String    @id @default(uuid())
  orgId        String    @map("org_id")
  name         String
  jobType      String    @map("job_type") // qc, classify, reminder, stats
  schedule     String? // cron expression
  config       Json      @default("{}")
  rulesContent String?   @map("rules_content")
  status       String    @default("active") // active, paused
  lastRunAt    DateTime? @map("last_run_at")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  org  Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  runs JobRun[]

  @@map("jobs")
}

// Execution history for a job
model JobRun {
  id           String    @id @default(uuid())
  jobId        String    @map("job_id")
  startedAt    DateTime  @map("started_at")
  finishedAt   DateTime? @map("finished_at")
  status       String    @default("running") // running, success, error
  summary      Json      @default("{}")
  errorMessage String?   @map("error_message")
  createdAt    DateTime  @default(now()) @map("created_at")

  job     Job         @relation(fields: [jobId], references: [id], onDelete: Cascade)
  results JobResult[]

  @@map("job_runs")
}

// Individual result from a job run (e.g. QC flag, classification label)
model JobResult {
  id             String   @id @default(uuid())
  jobRunId       String   @map("job_run_id")
  conversationId String?  @map("conversation_id")
  resultType     String   @map("result_type")
  severity       String?
  ruleName       String?  @map("rule_name")
  evidence       String?
  detail         Json     @default("{}")
  aiRawResponse  String?  @map("ai_raw_response")
  confidence     Float    @default(1.0)
  createdAt      DateTime @default(now()) @map("created_at")

  jobRun JobRun @relation(fields: [jobRunId], references: [id], onDelete: Cascade)

  @@map("job_results")
}

// Audit trail for user actions
model ActivityLog {
  id         String   @id @default(uuid())
  orgId      String   @map("org_id")
  userId     String?  @map("user_id")
  action     String
  entityType String?  @map("entity_type")
  entityId   String?  @map("entity_id")
  details    Json     @default("{}")
  createdAt  DateTime @default(now()) @map("created_at")

  org  Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  user User?        @relation(fields: [userId], references: [id])

  @@map("activity_logs")
}

// Daily messaging statistics per user per Zalo account
model DailyMessageStat {
  id                String   @id @default(uuid())
  orgId             String   @map("org_id")
  userId            String   @map("user_id")
  zaloAccountId     String   @map("zalo_account_id")
  statDate          DateTime @map("stat_date") @db.Date
  messagesSent      Int      @default(0) @map("messages_sent")
  messagesReceived  Int      @default(0) @map("messages_received")
  messagesUnread    Int      @default(0) @map("messages_unread")
  messagesUnreplied Int      @default(0) @map("messages_unreplied")
  avgResponseTime   Int?     @map("avg_response_time_seconds")

  org         Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  zaloAccount ZaloAccount  @relation(fields: [zaloAccountId], references: [id], onDelete: Cascade)

  @@unique([userId, zaloAccountId, statDate])
  @@map("daily_message_stats")
}

// Encrypted or plain key-value settings per org
model AppSetting {
  id             String   @id @default(uuid())
  orgId          String   @map("org_id")
  settingKey     String   @map("setting_key")
  valuePlain     String?  @map("value_plain")
  valueEncrypted Bytes?   @map("value_encrypted")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  org Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@unique([orgId, settingKey])
  @@map("app_settings")
}

// Sales order linked to a contact (and optionally a conversation).
//
// HISTORY: This model started as a thin row populated by MISA imports
// (`order_code` = "XK*"). In Session 2 of the wholesale CRM build it was
// extended with the wholesale-order workflow: 6-status pipeline, payment
// tracking, debt management, shipping, gifts, batch links. Old MISA rows
// keep their original status/totalAmount; new rows from the UI populate
// the new `subtotalAmount`/`paidAmount`/`debtAmount` Decimal columns.
// The legacy `Float` `totalAmount` is mirrored to `total_amount_value`
// (Decimal) on every write so dashboards/resale-service keep working
// without changes.
model Order {
  id              String    @id @default(uuid())
  orgId           String    @map("org_id")
  contactId       String    @map("contact_id")
  createdByUserId String    @map("created_by_user_id")
  conversationId  String?   @map("conversation_id")
  orderCode       String    @map("order_code")
  // Legacy Float total — kept for backward compat with MISA-imported rows
  // and the dashboard/resale services that aggregate it. New wholesale
  // orders also write here so existing reports keep working.
  totalAmount     Float     @map("total_amount")
  // Real business date the customer placed the order. Falls back to
  // `createdAt` if staff doesn't enter it. All resale analytics use
  // this column (NOT createdAt) so historical imports can backfill.
  orderDate       DateTime? @map("order_date")
  // SKUs of products in this order. Stored as `["SKU-001", "SKU-002"]`
  // for now; structured as objects later if/when we add unit prices per
  // line. Used for product-level resale frequency analytics.
  productSkus     Json      @default("[]") @map("product_skus")
  // 6-status pipeline (new schema): draft | confirmed | packing |
  // shipping | completed | cancelled. Legacy MISA rows may still carry
  // "shipped"/"paid" until backfill — handled with status normalization
  // in the service layer.
  status          String    @default("draft")
  notes           String?
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  // ── Session 2 wholesale-order extension ───────────────────────────
  assignedSaleId   String?   @map("assigned_sale_id")
  mktOwnerId       String?   @map("mkt_owner_id")
  source           String? // facebook | zalo | gioi_thieu | khac
  shippingMethod   String?   @map("shipping_method") // pickup_at_warehouse | cod | prepaid
  shippingProvider String?   @map("shipping_provider")
  trackingCode     String?   @map("tracking_code")
  shippingFee      Decimal   @default(0) @map("shipping_fee") @db.Decimal(15, 2)
  deliveryAddress  String?   @map("delivery_address")
  recipientName    String?   @map("recipient_name")
  recipientPhone   String?   @map("recipient_phone")
  // Snapshots of the cart total (auto-computed in service):
  //   subtotalAmount  = SUM(line_total)
  //   discountAmount  = the resolved discount in VND (already applied)
  //   totalAmountValue = subtotal - discount + shipping_fee
  //   debtAmountValue  = total - paid (auto)
  subtotalAmount   Decimal?  @map("subtotal_amount") @db.Decimal(15, 2)
  discountType     String?   @map("discount_type") // percent | fixed
  discountValue    Decimal   @default(0) @map("discount_value") @db.Decimal(15, 2)
  discountAmount   Decimal   @default(0) @map("discount_amount") @db.Decimal(15, 2)
  totalAmountValue Decimal?  @map("total_amount_value") @db.Decimal(15, 2)
  paidAmount       Decimal   @default(0) @map("paid_amount") @db.Decimal(15, 2)
  debtAmountValue  Decimal   @default(0) @map("debt_amount_value") @db.Decimal(15, 2)
  paymentMethod    String?   @map("payment_method") // bank_transfer | cod | cash | credit
  debtDueDate      DateTime? @map("debt_due_date") @db.Date

  internalNote String? @map("internal_note")
  customerNote String? @map("customer_note")
  cancelReason String? @map("cancel_reason")

  // VAT placeholder for Easy Invoice integration (Session 2B)
  vatInvoiceId     String? @map("vat_invoice_id")
  vatInvoiceStatus String  @default("not_issued") @map("vat_invoice_status")
  vatInvoiceUrl    String? @map("vat_invoice_url")

  // Thông tin người mua để xuất hóa đơn VAT (per-order; prefill từ Contact,
  // cho phép override vì khách có thể tách nhiều công ty). Giá đã gồm VAT
  // nên KHÔNG tính thêm tiền — chỉ lưu thông tin để phát hành HĐ.
  needsVatInvoice  Boolean @default(false) @map("needs_vat_invoice")
  invoiceBuyerType String? @map("invoice_buyer_type") // ca_nhan | ho_kinh_doanh | cong_ty
  invoiceBuyerName String? @map("invoice_buyer_name")
  invoiceTaxCode   String? @map("invoice_tax_code") // MST (HKD/Công ty) hoặc CCCD (cá nhân)
  invoiceAddress   String? @map("invoice_address")
  invoiceEmail     String? @map("invoice_email")

  // Người giới thiệu đơn/khách (free text — có thể là đại lý, CTV, hoặc tên ngoài).
  referrerName     String? @map("referrer_name")

  // Stage timestamps
  confirmedAt DateTime? @map("confirmed_at")
  packedAt    DateTime? @map("packed_at")
  shippedAt   DateTime? @map("shipped_at")
  completedAt DateTime? @map("completed_at")
  cancelledAt DateTime? @map("cancelled_at")

  // Pre-FIFO orders carry per-line cost snapshots from MISA imports or
  // earlier sessions; their `unit_cost`/`line_cost` must NOT be touched
  // by the FIFO module. Defaults to false on new orders so the packing
  // transition runs the FIFO allocator instead of requiring a manual
  // batch pick.
  legacyCost Boolean @default(false) @map("legacy_cost")
  // ──────────────────────────────────────────────────────────────────

  org          Organization        @relation(fields: [orgId], references: [id], onDelete: Cascade)
  contact      Contact             @relation(fields: [contactId], references: [id], onDelete: Cascade)
  createdBy    User                @relation("CreatedOrders", fields: [createdByUserId], references: [id])
  assignedSale User?               @relation("AssignedSaleOrders", fields: [assignedSaleId], references: [id])
  mktOwner     User?               @relation("MktOwnerOrders", fields: [mktOwnerId], references: [id])
  conversation Conversation?       @relation(fields: [conversationId], references: [id])
  items        OrderItem[]
  gifts        OrderGift[]

  @@unique([orgId, orderCode])
  @@index([orgId, orderDate])
  @@index([orgId, contactId])
  @@index([orgId, status])
  @@index([orgId, assignedSaleId])
  @@index([orgId, debtDueDate])
  @@map("orders")
}

// Line items per order — populated from MISA "Sổ chi tiết bán hàng" or
// future order entry forms. Master Order keeps total/status; OrderItem
// powers product-level analytics (top SKU, brand mix, repurchase per SKU).
// `costValue` is sensitive (giá vốn) — only owner role may read it via API.
model OrderItem {
  id            String   @id @default(uuid())
  orderId       String   @map("order_id")
  sku           String // MH_01, BIO_07
  productName   String   @map("product_name")
  unit          String? // Hộp / Lọ / Bộ
  quantity      Float
  unitPrice     Float    @map("unit_price")
  discountValue Float    @default(0) @map("discount_value")
  lineTotal     Float    @map("line_total")
  costValue     Float?   @map("cost_value") // owner-only
  returnQty     Float    @default(0) @map("return_qty")
  returnValue   Float    @default(0) @map("return_value")
  createdAt     DateTime @default(now()) @map("created_at")

  // ── Session 2 wholesale-order extension ───────────────────────────
  // Link to the Product table (Session 1). Nullable because legacy MISA
  // imports populated only `sku` text.
  productId   String?  @map("product_id")
  // Which lot this line was picked from. Nullable for legacy rows / for
  // gift items that don't deduct stock from a specific batch.
  batchId     String?  @map("batch_id")
  // Which `product_prices` tier the unit_price came from. Snapshot —
  // editing the price tier later does not retroactively change the
  // order. Nullable for legacy rows / manual overrides.
  priceTierId String?  @map("price_tier_id")
  // Derived: `line_total - line_cost`. Owner/admin only.
  unitCost    Decimal? @map("unit_cost") @db.Decimal(15, 2)
  lineCost    Decimal? @map("line_cost") @db.Decimal(15, 2)
  profit      Decimal? @db.Decimal(15, 2)
  // ──────────────────────────────────────────────────────────────────

  order      Order            @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product    Product?         @relation(fields: [productId], references: [id])
  batch      InventoryBatch?  @relation(fields: [batchId], references: [id])
  tier       ProductPrice?    @relation(fields: [priceTierId], references: [id])
  // FIFO trace — one OrderItem can draw from multiple batches when a
  // single line spans more than one lot in the warehouse.
  fifoUsages OrderItemBatch[]

  @@index([orderId])
  @@index([sku])
  @@index([productId])
  @@index([batchId])
  @@map("order_items")
}

// ── Session 2: Wholesale order add-ons ──────────────────────────────
// Per-warehouse inventory lots with expiry tracking. Master "kho" record
// in `warehouses` (we ship from a single warehouse for now). When admin
// imports new stock through Session 3 they create one batch per shipment.
model Warehouse {
  id        String   @id @default(uuid())
  orgId     String   @map("org_id")
  name      String
  address   String?
  managerId String?  @map("manager_id")
  active    Boolean  @default(true)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  org     Organization     @relation(fields: [orgId], references: [id], onDelete: Cascade)
  batches InventoryBatch[]

  @@map("warehouses")
}

// One row per (product, lot, warehouse). `currentQuantity` is the live
// stock in the warehouse — decremented on order packing, incremented on
// cancel-after-packing or returns. `importQuantity` is the original
// amount when the lot was received (immutable after creation).
model InventoryBatch {
  id              String    @id @default(uuid())
  orgId           String    @map("org_id")
  productId       String    @map("product_id")
  warehouseId     String    @map("warehouse_id")
  batchCode       String    @map("batch_code")
  manufactureDate DateTime? @map("manufacture_date") @db.Date
  expiryDate      DateTime? @map("expiry_date") @db.Date
  importQuantity  Int       @map("import_quantity")
  currentQuantity Int       @map("current_quantity")
  importCost      Decimal?  @map("import_cost") @db.Decimal(15, 2)
  status          String    @default("active") // active | expired | recalled
  importedAt      DateTime  @default(now()) @map("imported_at")
  createdById     String?   @map("created_by")
  notes           String?
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")
  // Provenance — lots created by the FIFO module link back to the import
  // order + supplier. Both nullable to keep legacy batches (created
  // pre-FIFO via the inventory dashboard) valid without a backfill.
  importOrderId   String?   @map("import_order_id")
  supplierId      String?   @map("supplier_id")

  org         Organization        @relation(fields: [orgId], references: [id], onDelete: Cascade)
  product     Product             @relation(fields: [productId], references: [id], onDelete: Cascade)
  warehouse   Warehouse           @relation(fields: [warehouseId], references: [id])
  orderItems  OrderItem[]
  orderGifts  OrderGift[]
  movements   InventoryMovement[]
  importOrder ImportOrder?        @relation(fields: [importOrderId], references: [id])
  supplier    Supplier?           @relation(fields: [supplierId], references: [id])
  fifoUsages  OrderItemBatch[]

  @@unique([orgId, productId, batchCode])
  @@index([orgId, productId, status])
  @@index([orgId, expiryDate])
  @@index([importOrderId])
  @@map("inventory_batches")
}

// Free gift attached to an order. Two flavours:
//  - product gift: `productId` set, `batchId` set → deducts from stock
//                  on packing, restored on cancel-after-packing.
//  - custom gift:  productId / batchId NULL, free-text `giftName` (e.g.
//                  "Túi vải Manhae"). Does NOT touch inventory.
model OrderGift {
  id        String   @id @default(uuid())
  orderId   String   @map("order_id")
  productId String?  @map("product_id")
  batchId   String?  @map("batch_id")
  giftName  String   @map("gift_name")
  quantity  Int      @default(1)
  note      String?
  createdAt DateTime @default(now()) @map("created_at")

  order   Order           @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product?        @relation(fields: [productId], references: [id])
  batch   InventoryBatch? @relation(fields: [batchId], references: [id])

  @@index([orderId])
  @@map("order_gifts")
}

// Audit log for every quantity change on a batch. Reads write-only — no
// updates after insert. Used by the stock dashboard (Session 3) and to
// reconcile if a manual adjust differs from order traffic.
model InventoryMovement {
  id            String   @id @default(uuid())
  orgId         String   @map("org_id")
  productId     String   @map("product_id")
  batchId       String   @map("batch_id")
  type          String // import | export | adjust | return
  quantity      Int // signed; negative for export
  // Polymorphic reference — `referenceType` determines which table
  // `referenceId` points at (orders, import_orders, ...). No FK so the
  // same column can carry IDs from different parents.
  referenceType String?  @map("reference_type") // order | import_order | manual_adjust
  referenceId   String?  @map("reference_id")
  note          String?
  createdById   String?  @map("created_by")
  createdAt     DateTime @default(now()) @map("created_at")

  org   Organization   @relation(fields: [orgId], references: [id], onDelete: Cascade)
  batch InventoryBatch @relation(fields: [batchId], references: [id], onDelete: Cascade)

  @@index([orgId, productId, createdAt])
  @@index([batchId, createdAt])
  @@index([referenceType, referenceId])
  @@map("inventory_movements")
}

// Quick-reply templates — single shared set per organization.
// Five canonical entries (welcome, pricing, reward, legal, media) auto-seeded
// on first GET; staff click a chip in the chat input bar to send the
// corresponding content. Admin/owner can edit content + media URL.
model QuickReplyTemplate {
  id        String   @id @default(uuid())
  orgId     String   @map("org_id")
  key       String // welcome | pricing | reward | legal | media
  type      String   @default("text") // text | link | image | combined
  content   String   @default("")
  mediaUrl  String?  @map("media_url")
  updatedAt DateTime @updatedAt @map("updated_at")
  updatedBy String?  @map("updated_by")

  org Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@unique([orgId, key])
  @@map("quick_reply_templates")
}

// ── Task management ─────────────────────────────────────────────────
// Categories are a closed set of 10 canonical buckets shared across all
// orgs. Org-customisation lives in RecurringTaskRule + AutoTaskRule.
model TaskCategory {
  id          String  @id @default(uuid())
  key         String  @unique // NEW_LEAD, DAILY_POST, BIRTHDAY, ...
  name        String
  icon        String // emoji
  color       String // colour token (red / blue / pink / ...)
  description String?
  sortOrder   Int     @default(0) @map("sort_order")

  tasks          Task[]
  recurringRules RecurringTaskRule[]
  autoRules      AutoTaskRule[]

  @@map("task_categories")
}

// One actionable item assigned to a sale. Sources:
//   manual    — user-created
//   recurring — generated nightly from RecurringTaskRule
//   auto      — generated every 15min from AutoTaskRule (event-driven)
model Task {
  id              String    @id @default(uuid())
  orgId           String    @map("org_id")
  categoryId      String    @map("category_id")
  assignedToId    String    @map("assigned_to")
  contactId       String?   @map("contact_id")
  title           String
  description     String?
  dueDate         DateTime  @map("due_date") @db.Date
  dueTime         String?   @map("due_time") // 'HH:MM' local time
  priority        Int       @default(2) // 1=high 2=med 3=low
  status          String    @default("pending") // pending | in_progress | done | skipped
  source          String    @default("manual") // auto | recurring | manual
  recurringRuleId String?   @map("recurring_rule_id")
  parentTaskId    String?   @map("parent_task_id")
  createdAt       DateTime  @default(now()) @map("created_at")
  completedAt     DateTime? @map("completed_at")
  completionNote  String?   @map("completion_note")
  metadata        Json      @default("{}")

  org           Organization       @relation(fields: [orgId], references: [id], onDelete: Cascade)
  category      TaskCategory       @relation(fields: [categoryId], references: [id])
  assignedTo    User               @relation("AssignedTasks", fields: [assignedToId], references: [id])
  contact       Contact?           @relation(fields: [contactId], references: [id])
  recurringRule RecurringTaskRule? @relation(fields: [recurringRuleId], references: [id])
  parentTask    Task?              @relation("Subtasks", fields: [parentTaskId], references: [id])
  subtasks      Task[]             @relation("Subtasks")

  @@index([orgId, assignedToId, dueDate])
  @@index([orgId, status, dueDate])
  @@index([orgId, categoryId])
  @@map("tasks")
}

model RecurringTaskRule {
  id              String   @id @default(uuid())
  orgId           String   @map("org_id")
  categoryId      String   @map("category_id")
  name            String
  description     String?
  cronExpression  String   @map("cron_expression") // 'M H DOM MON DOW'
  appliesToRole   String   @default("all") @map("applies_to_role") // sale | csk | leader | all
  defaultQuantity Int      @default(1) @map("default_quantity")
  active          Boolean  @default(true)
  createdBy       String?  @map("created_by")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  org      Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  category TaskCategory @relation(fields: [categoryId], references: [id])
  tasks    Task[]

  @@map("recurring_task_rules")
}

model AutoTaskRule {
  id               String   @id @default(uuid())
  orgId            String   @map("org_id")
  categoryId       String   @map("category_id")
  triggerType      String   @map("trigger_type") // new_lead | birthday | inactive_chat | inactive_order | upsell_eligible
  triggerCondition Json     @default("{}") @map("trigger_condition")
  dueInHours       Int      @default(24) @map("due_in_hours")
  messageTemplate  String   @map("message_template")
  active           Boolean  @default(true)
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  org      Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  category TaskCategory @relation(fields: [categoryId], references: [id])

  @@map("auto_task_rules")
}

model LearningModule {
  id              String   @id @default(uuid())
  orgId           String   @map("org_id")
  name            String
  description     String?
  type            String   @default("optional") // required | optional
  sortOrder       Int      @default(0) @map("sort_order")
  contentUrl      String?  @map("content_url")
  durationMinutes Int      @default(0) @map("duration_minutes")
  forRoles        Json     @default("[]") @map("for_roles") // ['member','admin']
  active          Boolean  @default(true)
  createdAt       DateTime @default(now()) @map("created_at")

  org      Organization       @relation(fields: [orgId], references: [id], onDelete: Cascade)
  progress LearningProgress[]

  @@map("learning_modules")
}

// ── Sản phẩm / Brand / NCC (Module Bán hàng — Session 1) ────────────
// One supplier (NCC) → many brands → many products. Each product carries a
// flexible list of price tiers (CTV, đại lý cấp 1/2, lẻ niêm yết, + tier
// admin tự thêm). Cost price (`costPrice`) is owner/admin-only — backend
// strips it from list responses for `member` role.
model Supplier {
  id          String   @id @default(uuid())
  orgId       String   @map("org_id")
  name        String
  country     String?
  contactInfo String?  @map("contact_info")
  active      Boolean  @default(true)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  org              Organization     @relation(fields: [orgId], references: [id], onDelete: Cascade)
  brands           Brand[]
  importOrders     ImportOrder[]
  inventoryBatches InventoryBatch[]

  @@index([orgId, active])
  @@map("suppliers")
}

// ── FIFO module (Session 3.5) ─────────────────────────────────────────
// One header row per goods-receipt voucher. Drafts are editable; once
// confirmed the rows in `import_order_items` materialise into one
// `inventory_batches` per product line, and `inventory_movements` rows
// of type=import get appended for the audit trail. `confirmedAt` flips
// from null → now() exactly once.
model ImportOrder {
  id            String    @id @default(uuid())
  orgId         String    @map("org_id")
  importCode    String    @map("import_code") // NK-YYYYMM-NNN
  supplierId    String?   @map("supplier_id")
  importDate    DateTime  @default(now()) @map("import_date") @db.Date
  nccInvoiceNo  String?   @map("ncc_invoice_no")
  totalAmount   Decimal   @default(0) @map("total_amount") @db.Decimal(15, 2)
  totalQuantity Int       @default(0) @map("total_quantity")
  status        String    @default("draft") // draft | confirmed
  notes         String?
  attachments   Json      @default("[]") // [{name, url, type}]
  createdById   String?   @map("created_by")
  confirmedAt   DateTime? @map("confirmed_at")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  org      Organization      @relation(fields: [orgId], references: [id], onDelete: Cascade)
  supplier Supplier?         @relation(fields: [supplierId], references: [id])
  items    ImportOrderItem[]
  batches  InventoryBatch[]

  @@unique([orgId, importCode])
  @@index([orgId, importDate])
  @@index([orgId, supplierId])
  @@index([orgId, status])
  @@map("import_orders")
}

// One row per (import_order, product, lot). Confirming the parent
// import order copies these into `inventory_batches`. `batchCode` is
// scoped per (orgId, productId) — uniqueness is enforced on the batch
// table, not here, so a draft can carry duplicates that are caught at
// confirm time.
model ImportOrderItem {
  id              String    @id @default(uuid())
  importOrderId   String    @map("import_order_id")
  productId       String    @map("product_id")
  batchCode       String    @map("batch_code")
  quantity        Int
  unitCost        Decimal   @map("unit_cost") @db.Decimal(15, 2)
  manufactureDate DateTime? @map("manufacture_date") @db.Date
  expiryDate      DateTime? @map("expiry_date") @db.Date
  lineTotal       Decimal   @map("line_total") @db.Decimal(15, 2)
  notes           String?
  createdAt       DateTime  @default(now()) @map("created_at")

  importOrder ImportOrder @relation(fields: [importOrderId], references: [id], onDelete: Cascade)
  product     Product     @relation(fields: [productId], references: [id])

  @@index([importOrderId])
  @@index([productId])
  @@map("import_order_items")
}

// FIFO trace. Written by the FIFO allocator (Session 3.5B) when a new
// (`legacyCost=false`) order moves to packing. One OrderItem can have
// multiple rows here when the requested quantity spans more than one
// active lot. `costAtTime` snapshots the batch's `importCost` at
// allocation so margin reports stay correct even if we adjust the
// batch's import_cost later.
model OrderItemBatch {
  id           String   @id @default(uuid())
  orderItemId  String   @map("order_item_id")
  batchId      String   @map("batch_id")
  quantityUsed Int      @map("quantity_used")
  costAtTime   Decimal  @map("cost_at_time") @db.Decimal(15, 2)
  createdAt    DateTime @default(now()) @map("created_at")

  orderItem OrderItem      @relation(fields: [orderItemId], references: [id], onDelete: Cascade)
  batch     InventoryBatch @relation(fields: [batchId], references: [id])

  @@index([orderItemId])
  @@index([batchId])
  @@map("order_item_batches")
}

model Brand {
  id          String   @id @default(uuid())
  orgId       String   @map("org_id")
  name        String
  supplierId  String?  @map("supplier_id")
  description String?
  logoUrl     String?  @map("logo_url")
  active      Boolean  @default(true)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  org      Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  supplier Supplier?    @relation(fields: [supplierId], references: [id])
  products Product[]

  @@index([orgId, active])
  @@map("brands")
}

model Product {
  id                 String   @id @default(uuid())
  orgId              String   @map("org_id")
  sku                String
  name               String
  brandId            String?  @map("brand_id")
  packageSize        String?  @map("package_size")
  mainImageUrl       String?  @map("main_image_url")
  galleryUrls        Json     @default("[]") @map("gallery_urls")
  status             String   @default("active") // active | discontinued | coming_soon
  // Free-text rich description shown in product detail (editable by sale)
  description        String?
  // When false (default), members cannot create an order that exceeds
  // available stock for this product; owner/admin can override.
  allowOversell      Boolean  @default(false) @map("allow_oversell")
  // TPCN info
  mainUse            String?  @map("main_use")
  targetAudience     String?  @map("target_audience")
  usageMethod        String?  @map("usage_method")
  shelfLifeMonths    Int?     @map("shelf_life_months")
  registrationNumber String?  @map("registration_number")
  // Stock — totalStock will be auto-derived from batches in Session 3 (Inventory)
  totalStock         Int      @default(0) @map("total_stock")
  warningStock       Int      @default(30) @map("warning_stock")
  unit               String   @default("hộp") // hộp | lọ | chai | gói
  // Cost — sensitive, owner/admin only
  costPrice          Decimal? @map("cost_price") @db.Decimal(15, 2)
  // Marketing docs — list of { id, type, name, driveUrl, createdAt }
  marketingDocs      Json     @default("[]") @map("marketing_docs")
  createdById        String?  @map("created_by")
  updatedById        String?  @map("updated_by")
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")

  org              Organization      @relation(fields: [orgId], references: [id], onDelete: Cascade)
  brand            Brand?            @relation(fields: [brandId], references: [id])
  prices           ProductPrice[]
  batches          InventoryBatch[]
  orderItems       OrderItem[]
  orderGifts       OrderGift[]
  importOrderItems ImportOrderItem[]

  @@unique([orgId, sku])
  @@index([orgId, status])
  @@index([orgId, brandId])
  @@map("products")
}

model ProductPrice {
  id           String   @id @default(uuid())
  productId    String   @map("product_id")
  tierName     String   @map("tier_name")
  price        Decimal  @db.Decimal(15, 2)
  displayOrder Int      @default(0) @map("display_order")
  isDefault    Boolean  @default(false) @map("is_default")
  active       Boolean  @default(true)
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  product    Product     @relation(fields: [productId], references: [id], onDelete: Cascade)
  orderItems OrderItem[]

  @@index([productId, active, displayOrder])
  @@map("product_prices")
}

model LearningProgress {
  id          String    @id @default(uuid())
  userId      String    @map("user_id")
  moduleId    String    @map("module_id")
  status      String    @default("not_started") // not_started | in_progress | completed
  startedAt   DateTime? @map("started_at")
  completedAt DateTime? @map("completed_at")
  score       Int?

  user   User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  module LearningModule @relation(fields: [moduleId], references: [id], onDelete: Cascade)

  @@unique([userId, moduleId])
  @@map("learning_progress")
}
