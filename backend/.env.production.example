# Biến môi trường PRODUCTION (đặt trong Render → Environment).
# KHÔNG commit file .env thật. Đây chỉ là mẫu liệt kê các key.

NODE_ENV=production
HOST=0.0.0.0
# PORT: Render tự cấp, KHÔNG cần đặt.

# --- Database: Supabase (nút "Connect" trên cùng → Session pooler) ---
# DÙNG "Session pooler" (cổng 5432, IPv4) — hợp server luôn-bật + Prisma.
# KHÔNG dùng "Transaction pooler" (6543) và KHÔNG dùng "Direct" (IPv6, Render không nối được).
# Nhớ thay [PASSWORD] bằng mật khẩu database đã đặt khi tạo project.
DATABASE_URL=postgresql://postgres.xxxxx:[PASSWORD]@aws-0-ap-southeast-1.pooler.supabase.com:5432/postgres

# --- Bí mật: COPY Y HỆT từ .env hiện tại trên máy ---
# ⚠ ENCRYPTION_KEY phải GIỐNG HỆT key cũ, nếu không sẽ KHÔNG giải mã được phiên Zalo đã lưu.
ENCRYPTION_KEY=copy-tu-env-hien-tai
JWT_SECRET=copy-tu-env-hien-tai

# --- URL công khai (giao diện trên Vercel) ---
APP_URL=https://sale.halo.com.vn
PUBLIC_URL=https://sale.halo.com.vn

# --- Nơi lưu file upload (trùng mountPath đĩa Render) ---
UPLOAD_DIR=/var/data/files

# --- Tuỳ chọn (để trống nếu không dùng) ---
PANCAKE_API_KEY=
