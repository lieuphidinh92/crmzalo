# ── Dependencies ─────────────────────────────────────────────────────
# KHÔNG dùng dấu "/" cuối để phủ cả symlink `node_modules` (thủ thuật
# iCloud `.nosync` trên Mac) lẫn thư mục thật. Bao luôn bản Finder nhân
# đôi ("node_modules 2") và mọi thư mục *.nosync — đây là thứ làm git
# quét chậm mỗi lần status/commit.
node_modules
**/node_modules
**/node_modules*
*.nosync
**/*.nosync
.pnpm-store/

# ── Build artifacts ─────────────────────────────────────────────────
dist/
**/dist/
build/
**/build/
out/
*.tsbuildinfo

# ── Environment / secrets ───────────────────────────────────────────
.env
.env.local
.env.*.local
**/.env
!.env.example

# ── Prisma generated client ─────────────────────────────────────────
backend/node_modules/.prisma/
backend/prisma/migrations/

# ── Logs ────────────────────────────────────────────────────────────
*.log
logs/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ── Runtime files ───────────────────────────────────────────────────
backups/
var/
backend/var/
*.pid
*.seed
*.pid.lock

# ── Test / coverage ─────────────────────────────────────────────────
coverage/
*.lcov
.nyc_output/

# ── PWA generated icons (can be regenerated from favicon.svg) ──────
# Keep them in repo for now since they ship with the build.
# frontend/public/icons/

# ── Editor / OS ─────────────────────────────────────────────────────
.DS_Store
.vscode/*
!.vscode/extensions.json
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# ── Misc ────────────────────────────────────────────────────────────
*.tgz
.npm/
.yarn-integrity
.cache/

# Local data snapshots (chứa dữ liệu KH/sản phẩm) — không commit
backend/scripts/backup-*.json
